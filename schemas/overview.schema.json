{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "overview.schema.json",
  "title": "Department overview (ARD §4.4)",
  "type": "object",
  "additionalProperties": false,
  "required": ["department", "name", "description", "sub_units", "personnel", "updated_at"],
  "properties": {
    "department": { "type": "string", "pattern": "^[a-z]+$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "sub_units": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "description"],
        "properties": { "name": { "type": "string" }, "description": { "type": "string" } }
      }
    },
    "personnel": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["role", "duties"],
        "properties": {
          "role": { "type": "string" },
          "duties": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "updated_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$" }
  }
}
