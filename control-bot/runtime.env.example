# Runtime profile for claude-code-telegram (ARD §3, §12) — SAMPLE, no real secrets.
# Copy outside git (or into Docker secrets) and fill in.

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Only the primary user's Telegram ID (NFR-1). Variable name is ALLOWED_USERS in this bot.
ALLOWED_USERS=

# Locked runtime profile (INV-2): the session can only reach data-repo, never code.
APPROVED_DIRECTORY=/path/to/data-repo
AGENTIC_MODE=false
CLAUDE_ALLOWED_TOOLS=Read,Write,Edit,Bash,Glob,Grep,Task

# Uploads only via Bot 1 (FR-U8); built-in Whisper/Voxtral transcription unused (ARD §12).
ENABLE_FILE_UPLOADS=false

# Budget & time, sized for Opus multi-stage runs (NFR-5)
CLAUDE_TIMEOUT_SECONDS=
CLAUDE_MAX_TURNS=
CLAUDE_MAX_COST_PER_USER=
CLAUDE_MAX_COST_PER_REQUEST=

# Auth: `claude auth` on the server, or:
ANTHROPIC_API_KEY=
