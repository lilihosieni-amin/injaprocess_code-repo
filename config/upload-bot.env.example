# Upload bot (Bot 1) — SAMPLE, no real secrets (ARD §11)
TELEGRAM_BOT_TOKEN=
# Local Bot API server URL (tdlib/telegram-bot-api) — needed for >20MB voices (NFR-2)
TELEGRAM_API_BASE_URL=http://telegram-bot-api:8081
# Only the primary user's Telegram ID (NFR-1)
ALLOWED_USER_ID=
# Path to data-repo (the only point of connection, ARD §1)
DATA_ROOT=/path/to/data-repo
# Optional: reach Telegram through a proxy (e.g. a local SOCKS proxy).
# For SOCKS, install the extra first:  uv pip install "httpx[socks]"
# TELEGRAM_PROXY=socks5://127.0.0.1:2080
